{
  "name": "pest-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Prompt Evaluation & Scoring Toolkit - Monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "check": "biome check .",
    "format": "biome format --write .",
    "docs:dev": "pnpm --filter @pest/docs dev",
    "docs:build": "pnpm --filter @pest/docs build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7"
  },
  "volta": {
    "node": "24.14.0",
    "npm": "11.11.1"
  }
}
