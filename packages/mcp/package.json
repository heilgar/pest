{
  "name": "@heilgar/pest-mcp",
  "version": "0.0.4",
  "description": "Prompt Evaluation & Scoring Toolkit - MCP server testing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup/vitest": {
      "import": "./dist/setup-vitest.js",
      "types": "./dist/setup-vitest.d.ts"
    },
    "./setup/jest": {
      "import": "./dist/setup-jest.js",
      "types": "./dist/setup-jest.d.ts"
    },
    "./qa": {
      "import": "./dist/qa.js",
      "types": "./dist/qa.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": ["llm", "prompt", "testing", "mcp", "model-context-protocol", "evaluation", "ai"],
  "license": "MIT",
  "dependencies": {
    "@heilgar/pest-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0",
    "jest": ">=29.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": { "optional": true },
    "jest": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
