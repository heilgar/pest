    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^3.24.0"
  }
