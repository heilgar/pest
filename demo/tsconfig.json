{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "types": ["node", "vitest/globals", "@heilgar/pest-vitest"],
    "lib": ["es2022"],
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["tests", "*.ts"],
  "exclude": ["node_modules"]
}
